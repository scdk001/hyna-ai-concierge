# API server. Defaults bind to localhost so real borrower data is never exposed accidentally.
API_HOST=127.0.0.1
API_PORT=8787
DATA_DIR=.data
CORS_ORIGINS=http://127.0.0.1:4180,http://localhost:4180

# AI runtime. Use "demo" without a key, or "openai" for a real Responses API call.
AI_MODE=demo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-sol
REQUIRE_REAL_AI=false

# Frontend. Leave blank when the API is served behind the same domain.
VITE_API_BASE_URL=
VITE_REQUIRE_API=false
